<Page x:Class="ParkingApp.Views.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1A1A1A">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#111111" Padding="24,16">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Доступні парковки"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="White"/>
                <TextBlock x:Name="ParkingCountText"
                           Text=""
                           FontSize="13"
                           Foreground="#888888"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Scrollable parking list -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="16,12,16,16">
            <WrapPanel x:Name="ParkingPanel"
                       Orientation="Horizontal"
                       HorizontalAlignment="Left"/>
        </ScrollViewer>
    </Grid>
</Page>
