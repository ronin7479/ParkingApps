<Window x:Class="ParkingApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Паркування - Вхід"
        Height="800"
        Width="680"
        MinHeight="700"
        MinWidth="560"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A1A"
        ResizeMode="CanResize">
    <Window.Resources>
        <Style x:Key="YellowButton" TargetType="Button">
            <Setter Property="Background" Value="#FFD700"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="10,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFC200"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GrayButton" TargetType="Button">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="10,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#444444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputField" TargetType="TextBox">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="SelectionBrush" Value="#FFD700"/>
            <Setter Property="SelectionTextBrush" Value="#1A1A1A"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Stretch"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#FFD700"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#666666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PasswordField" TargetType="PasswordBox">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Stretch"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#FFD700"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#666666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- ScrollViewer ПЕРШИМ -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Width="520" Margin="20,80,20,40">

                <!-- Logo -->
                <TextBlock Text="🅿️" FontSize="48" TextAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="ПАРКУВАННЯ"
                           FontSize="26" FontWeight="Bold"
                           Foreground="#FFD700"
                           TextAlignment="Center"
                           Margin="0,0,0,6"/>

                <TextBlock Text="Вхід до облікового запису"
                           FontSize="13"
                           Foreground="#888888"
                           TextAlignment="Center"
                           Margin="0,0,0,32"/>

                <!-- Test account hint -->
                <Border Background="#2A2A1A"
                        BorderBrush="#FFD700"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="16,12"
                        Margin="0,0,0,28">
                    <StackPanel>
                        <TextBlock Text="🔑 Тестовий акаунт"
                                   Foreground="#FFD700"
                                   FontWeight="Bold"
                                   FontSize="13"
                                   Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Логін:" Foreground="#888888" FontSize="12" Width="55"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="testuser" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Пароль:" Foreground="#888888" FontSize="12" Width="55" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="test123" Foreground="White" FontSize="12" FontWeight="SemiBold" Margin="0,4,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Login field -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Логін"
                               Foreground="#AAAAAA" FontSize="13"
                               VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1"
                             x:Name="LoginTextBox"
                             Style="{StaticResource InputField}"/>
                </Grid>

                <!-- Password field -->
                <Grid Margin="0,0,0,28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Пароль"
                               Foreground="#AAAAAA" FontSize="13"
                               VerticalAlignment="Center"/>
                    <PasswordBox Grid.Column="1"
                                 x:Name="PasswordBox"
                                 Style="{StaticResource PasswordField}"/>
                </Grid>

                <!-- Auto-login button -->
                <Button Content="⚡ Автовхід (тестовий акаунт)"
                        Height="50"
                        Style="{StaticResource GrayButton}"
                        Click="AutoLoginButton_Click"
                        Margin="0,0,0,12"/>

                <!-- Login button -->
                <Button Content="Увійти"
                        Height="54"
                        Style="{StaticResource YellowButton}"
                        Click="LoginButton_Click"
                        Margin="0,0,0,12"/>

                <!-- Register button -->
                <Button Content="Створити акаунт"
                        Height="50"
                        Style="{StaticResource GrayButton}"
                        Click="RegisterButton_Click"/>

                <!-- Error message -->
                <TextBlock x:Name="ErrorMessage"
                           Foreground="#FF6B6B"
                           TextWrapping="Wrap"
                           Margin="0,16,0,0"
                           FontSize="13"
                           TextAlignment="Center"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Admin button - ПІСЛЯ ScrollViewer щоб бути поверх нього -->
        <Button x:Name="AdminButton"
                Content="🔐 Адмін"
                Width="120"
                Height="42"
                VerticalAlignment="Top"
                HorizontalAlignment="Right"
                Margin="0,16,16,0"
                Style="{StaticResource GrayButton}"
                Click="AdminButton_Click"
                Panel.ZIndex="10"/>
    </Grid>
</Window>
