<Page x:Class="ParkingApp.Views.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1A1A1A">
    <Page.Resources>
        <Style x:Key="LogoutBtn" TargetType="Button">
            <Setter Property="Background" Value="#3A1A1A"/>
            <Setter Property="Foreground" Value="#FF6B6B"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#FF6B6B"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="20,10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#4A2020"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#111111" Padding="24,16">
            <TextBlock Text="Мій профіль"
                       FontSize="22" FontWeight="Bold" Foreground="White"/>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24">
            <StackPanel>

                <!-- Avatar + name -->
                <StackPanel HorizontalAlignment="Center" Margin="0,8,0,28">
                    <Border Width="80" Height="80"
                            CornerRadius="40"
                            Background="#333333"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,12">
                        <TextBlock x:Name="AvatarLetter"
                                   Text="U"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="#F5F5DC"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="LoginDisplayText"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="White"
                               TextAlignment="Center"/>
                </StackPanel>

                <!-- Info card -->
                <Border Background="#222222"
                        CornerRadius="14"
                        Padding="20"
                        Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Інформація акаунту"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Foreground="#FFD700"
                                   Margin="0,0,0,16"/>
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Логін"
                                       Foreground="#888888" FontSize="13"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="LoginText"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <Border Height="1" Background="#333333" Margin="0,0,0,12"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Електронна пошта"
                                       Foreground="#888888" FontSize="13"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="EmailText"
                                       FontSize="14"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Stats card -->
                <Border Background="#222222"
                        CornerRadius="14"
                        Padding="20"
                        Margin="0,0,0,28">
                    <StackPanel>
                        <TextBlock Text="Статистика"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Foreground="#FFD700"
                                   Margin="0,0,0,16"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Бронювань"
                                       Foreground="#888888" FontSize="13"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="BookingsCountText"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Logout button — внизу праворуч -->
                <Button x:Name="LogoutButton"
                        Content="🚪  Вийти з акаунту"
                        Style="{StaticResource LogoutBtn}"
                        Width="200"
                        Height="46"
                        HorizontalAlignment="Right"
                        Click="LogoutButton_Click"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
