<Window x:Class="ParkingApp.Views.AdminLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Адміністратор - Вхід"
        Height="780"
        Width="660"
        MinHeight="680"
        MinWidth="560"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A1A"
        ResizeMode="CanResize">
    <Window.Resources>
        <Style x:Key="OrangeButton" TargetType="Button">
            <Setter Property="Background" Value="#FF8C00"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="10,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF6B00"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GrayButton" TargetType="Button">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="10,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#444444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="InputField" TargetType="TextBox">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PasswordField" TargetType="PasswordBox">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                    Width="520" Margin="20,50,20,40">

            <TextBlock Text="🔐" FontSize="42" TextAlignment="Center" Margin="0,0,0,6"/>
            <TextBlock Text="АДМІНІСТРАТОР"
                       FontSize="22" FontWeight="Bold"
                       Foreground="#FF8C00"
                       TextAlignment="Center"
                       Margin="0,0,0,8"/>
            <TextBlock Text="Вхід до панелі управління"
                       FontSize="13"
                       Foreground="#888888"
                       TextAlignment="Center"
                       Margin="0,0,0,32"/>

            <!-- Admin credentials hint -->
            <Border Background="#1E1410"
                    BorderBrush="#FF8C00"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="16,12"
                    Margin="0,0,0,28">
                <StackPanel>
                    <TextBlock Text="🔑 Адмін-дані для входу"
                               Foreground="#FF8C00"
                               FontWeight="Bold"
                               FontSize="13"
                               Margin="0,0,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Логін:" Foreground="#888888" FontSize="12" Width="60"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="AdminParking" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Пароль:" Foreground="#888888" FontSize="12" Width="60" Margin="0,4,0,0"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="2026KRparking!" Foreground="White" FontSize="12" FontWeight="SemiBold" Margin="0,4,0,0"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Login field -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Логін"
                           Foreground="#AAAAAA" FontSize="13"
                           VerticalAlignment="Center"/>
                <TextBox Grid.Column="1"
                         x:Name="AdminLoginTextBox"
                         Style="{StaticResource InputField}"/>
            </Grid>

            <!-- Password field -->
            <Grid Margin="0,0,0,28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Пароль"
                           Foreground="#AAAAAA" FontSize="13"
                           VerticalAlignment="Center"/>
                <PasswordBox Grid.Column="1"
                             x:Name="AdminPasswordBox"
                             Style="{StaticResource PasswordField}"/>
            </Grid>

            <Button Content="Увійти як адмін"
                    Height="54"
                    Style="{StaticResource OrangeButton}"
                    Click="AdminLoginButton_Click"
                    Margin="0,0,0,12"/>

            <Button Content="← Назад"
                    Height="50"
                    Style="{StaticResource GrayButton}"
                    Click="BackButton_Click"/>

            <TextBlock x:Name="ErrorMessage"
                       Foreground="#FF6B6B"
                       TextWrapping="Wrap"
                       Margin="0,16,0,0"
                       FontSize="13"
                       TextAlignment="Center"/>
        </StackPanel>
    </ScrollViewer>
</Window>
