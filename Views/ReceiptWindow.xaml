<Window x:Class="ParkingApp.Views.ReceiptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Квитанція"
        Height="560"
        Width="500"
        MinHeight="480"
        MinWidth="420"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A1A"
        ResizeMode="CanResize">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                    Width="420" Margin="20,30,20,30">

            <!-- Success icon -->
            <TextBlock Text="✅" FontSize="52" TextAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock Text="Оплата пройшла успішно!"
                       FontSize="18" FontWeight="Bold"
                       Foreground="#4CAF50"
                       TextAlignment="Center"
                       Margin="0,0,0,24"/>

            <!-- Receipt card -->
            <Border Background="#222222"
                    CornerRadius="16"
                    Padding="24,20"
                    Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="КВИТАНЦІЯ ПРО ОПЛАТУ"
                               FontSize="13"
                               FontWeight="Bold"
                               Foreground="#FFD700"
                               TextAlignment="Center"
                               Margin="0,0,0,16"/>

                    <Border Height="1" Background="#333333" Margin="0,0,0,16"/>

                    <!-- Receipt Number -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Номер квитанції"
                                   Foreground="#888888" FontSize="13"/>
                        <TextBlock Grid.Column="1" x:Name="ReceiptNumberText"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="#FFD700"
                                   TextAlignment="Right"/>
                    </Grid>

                    <!-- Date -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Дата платежу"
                                   Foreground="#888888" FontSize="13"/>
                        <TextBlock Grid.Column="1" x:Name="PaymentDateText"
                                   FontSize="13" Foreground="White" TextAlignment="Right"/>
                    </Grid>

                    <Border Height="1" Background="#333333" Margin="0,8,0,12"/>

                    <!-- Parking -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Паркування"
                                   Foreground="#888888" FontSize="13"/>
                        <TextBlock Grid.Column="1" x:Name="ParkingNameText"
                                   FontSize="13" Foreground="White"
                                   TextAlignment="Right"
                                   TextWrapping="Wrap"/>
                    </Grid>

                    <!-- Space -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Місце №"
                                   Foreground="#888888" FontSize="13"/>
                        <TextBlock Grid.Column="1" x:Name="SpaceNumberText"
                                   FontSize="13" Foreground="White" TextAlignment="Right"/>
                    </Grid>

                    <!-- Car -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Номер авто"
                                   Foreground="#888888" FontSize="13"/>
                        <TextBlock Grid.Column="1" x:Name="CarNumberText"
                                   FontSize="13" FontWeight="Bold"
                                   Foreground="White" TextAlignment="Right"/>
                    </Grid>

                    <Border Height="1" Background="#333333" Margin="0,8,0,12"/>

                    <!-- Total -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="СУМА"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock Grid.Column="1" x:Name="AmountText"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="#FFD700" TextAlignment="Right"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- OK button -->
            <Button Content="Окей"
                    Height="48"
                    FontSize="15"
                    FontWeight="Bold"
                    Cursor="Hand"
                    Click="OkButton_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#FFD700" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFC200"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
                <Button.Foreground>
                    <SolidColorBrush Color="#1A1A1A"/>
                </Button.Foreground>
            </Button>
        </StackPanel>
    </ScrollViewer>
</Window>
