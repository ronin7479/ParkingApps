<Window x:Class="ParkingApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Паркування"
        Height="820"
        Width="1440"
        MinHeight="600"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A1A">
    <Window.Resources>
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Height" Value="54"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Margin="8,2">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#2A2A2A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="NavButtonActive" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Background" Value="#2A2A1A"/>
            <Setter Property="Foreground" Value="#FFD700"/>
        </Style>
        <Style x:Key="LogoutButton" TargetType="Button">
            <Setter Property="Background" Value="#2A1A1A"/>
            <Setter Property="Foreground" Value="#FF6B6B"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="54"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Margin="8,2">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A2020"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" MinWidth="220" MaxWidth="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#111111" CornerRadius="0,0,0,0">
            <DockPanel>
                <!-- Logo area -->
                <StackPanel DockPanel.Dock="Top" Margin="16,24,16,16">
                    <TextBlock Text="🅿️ ПАРКУВАННЯ"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#FFD700"
                               TextAlignment="Center"
                               Margin="0,0,0,4"/>
                    <Border Height="1" Background="#333333" Margin="0,16,0,8"/>
                </StackPanel>

                <!-- User avatar area -->
                <StackPanel DockPanel.Dock="Top" HorizontalAlignment="Center" Margin="0,0,0,20">
                    <Border Width="56" Height="56"
                            CornerRadius="28"
                            Background="#333333"
                            HorizontalAlignment="Center">
                        <TextBlock x:Name="AvatarLetter"
                                   Text="U"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#F5F5DC"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="UserNameLabel"
                               Text="Користувач"
                               Foreground="White"
                               FontSize="13"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Bottom logout -->
                <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,24">
                    <Border Height="1" Background="#333333" Margin="16,0,16,12"/>
                    <Button x:Name="LogoutSideButton"
                            Content="🚪  Вийти"
                            Style="{StaticResource LogoutButton}"
                            Click="LogoutButton_Click"/>
                </StackPanel>

                <!-- Nav buttons -->
                <StackPanel Margin="0,4,0,0">
                    <Button x:Name="MainNavButton"
                            Content="🏠  Головна"
                            Style="{StaticResource NavButtonActive}"
                            Click="MainButton_Click"/>
                    <Button x:Name="ProfileNavButton"
                            Content="👤  Профіль"
                            Style="{StaticResource NavButton}"
                            Click="ProfileButton_Click"/>
                    <Button x:Name="BookingsNavButton"
                            Content="📋  Мої бронювання"
                            Style="{StaticResource NavButton}"
                            Click="BookingsButton_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Content -->
        <Border Grid.Column="1" Background="#1A1A1A" Margin="0">
            <Frame x:Name="ContentFrame" NavigationUIVisibility="Hidden" Background="Transparent"/>
        </Border>
    </Grid>
</Window>
