<Window x:Class="ParkingApp.Views.PaymentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Оплата паркування"
        Height="820"
        Width="760"
        MinHeight="700"
        MinWidth="640"
        WindowStartupLocation="CenterOwner"
        Background="#1A1A1A"
        ResizeMode="CanResize">
    <Window.Resources>
        <Style x:Key="InputField" TargetType="TextBox">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ComboField" TargetType="ComboBox">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Background" Value="#2A2A2A"/>
                        <Setter Property="FontSize" Value="15"/>
                        <Setter Property="Padding" Value="14,10"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter Property="Background" Value="#3A3A1A"/>
                                            <Setter Property="Foreground" Value="#FFD700"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <Grid>
                                
                                <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  VerticalAlignment="Center"
                                                  Margin="14,0,36,0"
                                                  IsHitTestVisible="False">
                                    <ContentPresenter.Resources>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontSize" Value="15"/>
                                        </Style>
                                    </ContentPresenter.Resources>
                                </ContentPresenter>
                                <ToggleButton Focusable="False"
                                              IsChecked="{Binding Path=IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              HorizontalAlignment="Right"
                                              Width="36"
                                              Cursor="Hand">
                                    <TextBlock Text="▼" Foreground="#888888" FontSize="11"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </ToggleButton>
                                <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                       Placement="Bottom"
                                       AllowsTransparency="True"
                                       Focusable="False">
                                    <Border Background="#2A2A2A"
                                            BorderBrush="#444444"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                            MaxHeight="220">
                                        <ScrollViewer>
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="160"/>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Header -->
        <Border VerticalAlignment="Top" Background="#111111" Height="56">
            <TextBlock Text="💳 Оплата паркування"
                       FontSize="18" FontWeight="Bold"
                       Foreground="White"
                       VerticalAlignment="Center"
                       Margin="24,0"/>
        </Border>

        <ScrollViewer Margin="0,56,0,0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="24,16,24,24">

                <!-- Parking name -->
                <Border Background="#222222" CornerRadius="12" Padding="16,12" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="Паркування" Foreground="#FFD700"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock x:Name="ParkingNameText" Foreground="White"
                                   FontSize="15" FontWeight="Bold"/>
                        <TextBlock x:Name="ParkingPriceText" Foreground="#888888"
                                   FontSize="12" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Car number -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Номер авто" Style="{StaticResource LabelText}"/>
                        <TextBlock Text="Формат: АА1234ВВ"
                                   Foreground="#666666" FontSize="10" Margin="0,2,0,0"/>
                    </StackPanel>
                    <TextBox Grid.Column="1" x:Name="CarNumberTextBox"
                             Style="{StaticResource InputField}"
                             MaxLength="8"
                             CharacterCasing="Upper"
                             TextChanged="CarNumber_TextChanged"/>
                </Grid>

                <!-- Date -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Дата паркування"
                               Style="{StaticResource LabelText}"/>
                    <DatePicker Grid.Column="1" x:Name="BookingDatePicker"
                                Height="52"
                                BorderBrush="#444444"
                                BorderThickness="1"
                                FontSize="15"
                                Background="#2A2A2A"
                                Foreground="White">
                        <DatePicker.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#2A2A2A"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}" Color="White"/>
                            <Style TargetType="DatePickerTextBox">
                                <Setter Property="Background" Value="#2A2A2A"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="CaretBrush" Value="White"/>
                                <Setter Property="SelectionBrush" Value="#FFD700"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="14,0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DatePickerTextBox">
                                            <Border Background="#2A2A2A" BorderThickness="0" CornerRadius="10">
                                                <Grid>
                                                    <ScrollViewer x:Name="PART_ContentHost"
                                                                  Margin="14,0"
                                                                  VerticalAlignment="Center"
                                                                  Foreground="White"/>
                                                    <TextBlock x:Name="PART_Watermark"
                                                               Text="дд.мм.рррр"
                                                               Foreground="#666666"
                                                               FontSize="14"
                                                               Margin="14,0"
                                                               VerticalAlignment="Center"
                                                               IsHitTestVisible="False"
                                                               Visibility="Collapsed"/>
                                                </Grid>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DatePicker.Resources>
                        <DatePicker.Template>
                            <ControlTemplate TargetType="DatePicker">
                                <Border Background="#2A2A2A"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        <DatePickerTextBox x:Name="PART_TextBox"
                                                           Grid.Column="0"
                                                           Foreground="White"
                                                           Background="#2A2A2A"
                                                           VerticalAlignment="Center"/>
                                        <Button x:Name="PART_Button"
                                                Grid.Column="1"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="Transparent" Padding="4">
                                                        <TextBlock Text="📅" FontSize="16"
                                                                   VerticalAlignment="Center"
                                                                   HorizontalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <Popup x:Name="PART_Popup"
                                               Grid.Column="0"
                                               AllowsTransparency="True"
                                               Placement="Bottom"
                                               StaysOpen="False"/>
                                    </Grid>
                                </Border>
                            </ControlTemplate>
                        </DatePicker.Template>
                    </DatePicker>
                </Grid>

                <!-- Time -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Час" Style="{StaticResource LabelText}"/>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Початок (ГГ:ХХ)"
                                   Foreground="#666666" FontSize="10" Margin="0,0,0,3"/>
                        <TextBox x:Name="StartTimeTextBox"
                                 Style="{StaticResource InputField}"
                                 MaxLength="5" TextChanged="Time_TextChanged"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2"/>
                    <StackPanel Grid.Column="3">
                        <TextBlock Text="Кінець (ГГ:ХХ)"
                                   Foreground="#666666" FontSize="10" Margin="0,0,0,3"/>
                        <TextBox x:Name="EndTimeTextBox"
                                 Style="{StaticResource InputField}"
                                 MaxLength="5" TextChanged="Time_TextChanged"/>
                    </StackPanel>
                </Grid>

                <!-- Parking space -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Місце паркування"
                               Style="{StaticResource LabelText}"/>
                    <ComboBox Grid.Column="1" x:Name="SpaceNumberComboBox"
                              Style="{StaticResource ComboField}"/>
                </Grid>

                <!-- Card number -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Номер картки" Style="{StaticResource LabelText}"/>
                        <TextBlock Text="16 цифр"
                                   Foreground="#666666" FontSize="10" Margin="0,2,0,0"/>
                    </StackPanel>
                    <TextBox Grid.Column="1" x:Name="CardNumberTextBox"
                             Style="{StaticResource InputField}"
                             MaxLength="19"
                             TextChanged="CardNumber_TextChanged"/>
                </Grid>

                <!-- Price summary -->
                <Border Background="#2A2A1A"
                        BorderBrush="#FFD700"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="16,14"
                        Margin="0,8,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Сума до оплати:"
                                   Foreground="#AAAAAA" FontSize="14"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" x:Name="PriceText"
                                   Text="0 грн" FontSize="22" FontWeight="Bold"
                                   Foreground="#FFD700"/>
                    </Grid>
                </Border>

                <!-- Buttons -->
                <Grid Height="50" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="✅ Оплатити"
                            Background="#FFD700" Foreground="#1A1A1A"
                            FontSize="15" FontWeight="Bold"
                            BorderThickness="0" Cursor="Hand"
                            Click="PaymentButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#FFC200"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Grid.Column="2" Content="✖ Скасувати"
                            Background="#333333" Foreground="#CCCCCC"
                            FontSize="14" BorderThickness="0" Cursor="Hand"
                            Click="CancelButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#444444"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <TextBlock x:Name="ErrorMessage"
                           Foreground="#FF6B6B"
                           TextWrapping="Wrap"
                           FontSize="13"
                           TextAlignment="Center"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
