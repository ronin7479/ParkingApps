<Window x:Class="ParkingApp.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Паркування - Реєстрація"
        Height="800"
        Width="680"
        MinHeight="700"
        MinWidth="560"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A1A"
        ResizeMode="CanResize">
    <Window.Resources>
        <Style x:Key="YellowButton" TargetType="Button">
            <Setter Property="Background" Value="#FFD700"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="10,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFC200"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="GrayButton" TargetType="Button">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="10,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#444444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="InputField" TargetType="TextBox">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PasswordField" TargetType="PasswordBox">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                    Width="520" Margin="20,40,20,40">

            <TextBlock Text="🅿️" FontSize="40" TextAlignment="Center" Margin="0,0,0,6"/>
            <TextBlock Text="РЕЄСТРАЦІЯ"
                       FontSize="24" FontWeight="Bold"
                       Foreground="#FFD700"
                       TextAlignment="Center"
                       Margin="0,0,0,8"/>
            <TextBlock Text="Створіть новий акаунт"
                       FontSize="13"
                       Foreground="#888888"
                       TextAlignment="Center"
                       Margin="0,0,0,32"/>

            <!-- Email -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Email"
                           Foreground="#AAAAAA" FontSize="13"
                           VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" x:Name="EmailTextBox"
                         Style="{StaticResource InputField}"/>
            </Grid>

            <!-- Login -->
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Логін"
                           Foreground="#AAAAAA" FontSize="13"
                           VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" x:Name="LoginTextBox"
                         Style="{StaticResource InputField}"/>
            </Grid>

            <!-- Password -->
            <Grid Margin="0,0,0,28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Пароль"
                           Foreground="#AAAAAA" FontSize="13"
                           VerticalAlignment="Center"/>
                <PasswordBox Grid.Column="1" x:Name="PasswordBox"
                             Style="{StaticResource PasswordField}"/>
            </Grid>

            <TextBlock Text="Пароль має бути не менше 6 символів"
                       Foreground="#666666" FontSize="11"
                       Margin="130,0,0,20"/>

            <Button Content="Зареєструватись"
                    Height="54"
                    Style="{StaticResource YellowButton}"
                    Click="RegisterButton_Click"
                    Margin="0,0,0,12"/>

            <Button Content="← Назад до входу"
                    Height="44"
                    Style="{StaticResource GrayButton}"
                    Click="BackButton_Click"/>

            <TextBlock x:Name="Message"
                       TextWrapping="Wrap"
                       Margin="0,16,0,0"
                       FontSize="13"
                       TextAlignment="Center"/>
        </StackPanel>
    </ScrollViewer>
</Window>
